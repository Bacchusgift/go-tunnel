#!/bin/bash
set -e

COMPOSE_DIR="$(cd "$(dirname "$0")" && pwd)"

echo "=== go-tunnel 服务端部署 ==="

# 检查 .env
if [ ! -f "$COMPOSE_DIR/.env" ]; then
    cp "$COMPOSE_DIR/.env.example" "$COMPOSE_DIR/.env"
    echo "⚠️  已生成 .env，请编辑 TUNNEL_DOMAIN 后重新运行 deploy"
    echo "   nano $COMPOSE_DIR/.env"
    exit 1
fi

# 拉取最新代码
git pull origin main

# 编译二进制（需要 go 环境）
echo "🔨 编译中 ..."
mkdir -p bin
CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-s -w" -o bin/go-tunnel-server ./cmd/server

# 构建并启动
echo "🐳 构建镜像 ..."
docker compose up -d --build

echo ""
echo "✅ 部署完成!"
