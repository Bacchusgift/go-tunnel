#!/bin/bash
set -e

COMPOSE_DIR="/opt/go-tunnel"
REPO_URL="git@github.com:Bacchusgift/go-tunnel.git"
BRANCH="main"

echo "=== go-tunnel 服务端部署脚本 ==="

# 检查 Docker
if ! command -v docker &>/dev/null; then
    echo "❌ Docker 未安装，请先安装 Docker"
    exit 1
fi

if ! docker compose version &>/dev/null; then
    echo "❌ docker compose 未安装"
    exit 1
fi

# 首次部署：克隆仓库
if [ ! -d "$COMPOSE_DIR" ]; then
    echo "📦 克隆仓库到 $COMPOSE_DIR ..."
    git clone -b "$BRANCH" "$REPO_URL" "$COMPOSE_DIR"
else
    echo "📦 更新仓库 ..."
    cd "$COMPOSE_DIR"
    git fetch origin "$BRANCH"
    git reset --hard "origin/$BRANCH"
fi

cd "$COMPOSE_DIR"

echo "🔨 构建镜像 ..."
docker compose build --no-cache

echo "🚀 启动服务 ..."
docker compose up -d

echo ""
echo "✅ 部署完成!"
echo ""
echo "服务地址: http://127.0.0.1:8080"
echo ""
echo "常用命令:"
echo "  查看日志: docker compose -f $COMPOSE_DIR/docker-compose.yml logs -f"
echo "  停止服务: docker compose -f $COMPOSE_DIR/docker-compose.yml down"
echo "  重启服务: docker compose -f $COMPOSE_DIR/docker-compose.yml restart"
