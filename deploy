#!/bin/bash
set -e

COMPOSE_DIR="/opt/go-tunnel"
REPO_URL="git@github.com:Bacchusgift/go-tunnel.git"
BRANCH="main"

echo "=== go-tunnel 服务端部署脚本 ==="

# 检查 Docker
if ! command -v docker &>/dev/null; then
    echo "❌ Docker 未安装，请先安装 Docker"
    exit 1
fi

if ! docker compose version &>/dev/null; then
    echo "❌ docker compose 未安装"
    exit 1
fi

# 检查 .env 配置
if [ ! -f "$COMPOSE_DIR/.env" ]; then
    # 首次部署
    if [ ! -d "$COMPOSE_DIR" ]; then
        echo "📦 克隆仓库到 $COMPOSE_DIR ..."
        git clone -b "$BRANCH" "$REPO_URL" "$COMPOSE_DIR"
    fi

    if [ ! -f "$COMPOSE_DIR/.env" ]; then
        cp "$COMPOSE_DIR/.env.example" "$COMPOSE_DIR/.env"
    fi

    echo ""
    echo "⚠️  首次部署，请编辑配置文件："
    echo "   nano $COMPOSE_DIR/.env"
    echo ""
    echo "   至少设置 TUNNEL_DOMAIN（你的域名，如 example.com）"
    echo ""
    read -p "配置完成后按回车继续部署..." _
fi

cd "$COMPOSE_DIR"

# 更新代码（非首次也支持）
if [ "$1" = "--update" ] || git fetch origin "$BRANCH" 2>/dev/null; then
    if [ "$(git rev-parse HEAD)" != "$(git rev-parse origin/$BRANCH)" ]; then
        echo "📦 更新代码 ..."
        git pull origin "$BRANCH"
    fi
fi

echo "🔨 构建镜像 ..."
docker compose build --no-cache

echo "🚀 启动服务 ..."
docker compose up -d

echo ""
echo "✅ 部署完成!"
echo ""
echo "常用命令:"
echo "  查看日志: cd $COMPOSE_DIR && docker compose logs -f"
echo "  停止服务: cd $COMPOSE_DIR && docker compose down"
echo "  重启服务: cd $COMPOSE_DIR && docker compose restart"
echo "  更新部署: cd $COMPOSE_DIR && git pull && docker compose up -d --build"
